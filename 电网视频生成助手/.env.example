APP_ENV=dev
APP_NAME=Grid Video Agent
APP_RUNTIME_DIR=runtime
APP_DATABASE_PATH=runtime/grid_video_agent.db
AUTOMATION_SCHEDULER_ENABLED=true
AUTOMATION_POLL_SECONDS=30
DEFAULT_REFERENCE_IMAGE_PATH=assets/reference/person.png

PROVIDER_PRIORITY_LLM=openai_llm,mock_llm
PROVIDER_PRIORITY_IMAGE=volcengine_image,mock_image
PROVIDER_PRIORITY_VIDEO=volcengine_video,mock_video
PROVIDER_PRIORITY_TTS=volcengine_tts,mock_tts
PROVIDER_PRIORITY_SUBTITLE=local_subtitle
PROVIDER_PRIORITY_PUBLISH=douyin_publisher,mock_publisher

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

VOLCENGINE_AK=
VOLCENGINE_SK=
VOLCENGINE_API_KEY=
VOLCENGINE_IMAGE_REQ_KEY=seed3l_single_ip
VOLCENGINE_IMAGE_SERVICE=cv
VOLCENGINE_IMAGE_REGION=cn-north-1
VOLCENGINE_IMAGE_POLL_SECONDS=4
VOLCENGINE_IMAGE_MAX_POLLS=30
VOLCENGINE_VIDEO_API_KEY=
VOLCENGINE_VIDEO_SUBMIT_URL=https://operator.las.cn-beijing.volces.com/api/v1/contents/generations/tasks
VOLCENGINE_VIDEO_QUERY_URL=https://operator.las.cn-beijing.volces.com/api/v1/contents/generations/tasks/{task_id}
VOLCENGINE_VIDEO_CALLBACK_URL=
VOLCENGINE_VIDEO_MODEL=doubao-seedance-1-0-pro-250528
VOLCENGINE_VIDEO_REQ_KEY=jimeng_ti2v_v30_pro
VOLCENGINE_VIDEO_TEXT_REQ_KEY=jimeng_t2v_v30_1080p
VOLCENGINE_VIDEO_IMAGE_REQ_KEY=jimeng_i2v_first_v30_1080
VOLCENGINE_VIDEO_SERVICE=cv
VOLCENGINE_VIDEO_REGION=cn-north-1
VOLCENGINE_VIDEO_USE_OPERATOR=false
VOLCENGINE_VIDEO_SUBMIT_METHOD=POST
VOLCENGINE_VIDEO_QUERY_METHOD=GET
VOLCENGINE_VIDEO_POLL_SECONDS=5
VOLCENGINE_VIDEO_MAX_POLLS=24
VOLCENGINE_VIDEO_ASPECT_RATIO=9:16

VOLCENGINE_TTS_APPID=
VOLCENGINE_TTS_ACCESS_KEY=
VOLCENGINE_TTS_TOKEN=
VOLCENGINE_TTS_SECRET_KEY=
